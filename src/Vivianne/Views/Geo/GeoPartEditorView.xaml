<UserControl
    x:Class="TheXDS.Vivianne.Views.Geo.GeoPartEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:geo="clr-namespace:TheXDS.Vivianne.Models.Geo;assembly=VivLib"
    xmlns:geo1="clr-namespace:TheXDS.Vivianne.ViewModels.Geo;assembly=Vivianne.Common"
    xmlns:hlp="clr-namespace:TheXDS.Vivianne.Helpers"
    xmlns:local="clr-namespace:TheXDS.Vivianne.Views.Geo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcart="http://schemas.thexds.local/mcart"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vc="clr-namespace:TheXDS.Vivianne.ValueConverters"
    d:DataContext="{d:DesignInstance Type=geo1:GeoPartEditorViewModel}"
    d:DesignWidth="500"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:NumberBox}}" TargetType="ui:NumberBox">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style BasedOn="{StaticResource {x:Type ComboBox}}" TargetType="ComboBox">
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
        </Style>
        <mcart:NotNullToBooleanConverter x:Key="nn2bc" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Margin="5">
            Origin:<Run Text="{Binding State.Part.Origin, Mode=OneWay}" />
        </TextBlock>
        <TextBlock Grid.Row="1" Margin="5">
            Vertices:<Run Text="{Binding State.Part.Vertices.Length, Mode=OneWay}" />
        </TextBlock>
        <ui:NumberBox
            Grid.Row="2"
            hlp:Form.Label="Unk_0x14"
            Value="{Binding State.Unk_0x14, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <ui:NumberBox
            Grid.Row="3"
            hlp:Form.Label="Unk_0x18"
            Value="{Binding State.Unk_0x18, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <ui:NumberBox
            Grid.Row="4"
            hlp:Form.Label="Unk_0x1C"
            Value="{Binding State.Unk_0x1C, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <ui:NumberBox
            Grid.Row="5"
            hlp:Form.Label="Unk_0x24"
            Value="{Binding State.Unk_0x24, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <ui:NumberBox
            Grid.Row="6"
            hlp:Form.Label="Unk_0x2C"
            Value="{Binding State.Unk_0x2C, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <Separator
            Grid.RowSpan="7"
            Grid.Column="1"
            Margin="5" />
        <ComboBox
            Grid.RowSpan="2"
            Grid.Column="2"
            hlp:Form.Label="Face"
            DisplayMemberPath="Index"
            ItemsSource="{Binding State.Faces, Mode=OneWay}"
            SelectedItem="{Binding State.SelectedFace}" />
        <Image
            Grid.Row="2"
            Grid.RowSpan="3"
            Grid.Column="2"
            MaxWidth="220"
            MaxHeight="110"
            Margin="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Image.Source>
                <MultiBinding>
                    <MultiBinding.Converter>
                        <vc:FshImageConverter />
                    </MultiBinding.Converter>
                    <Binding Mode="OneWay" Path="State.SelectedFace.SelectedTexture" />
                    <Binding Mode="OneWay" Path="State.SelectedFace.Palette" />
                    <Binding Mode="OneWay" Path="State.SelectedFace.Alpha" />
                </MultiBinding>
            </Image.Source>
        </Image>
        <ComboBox
            Grid.Row="5"
            Grid.Column="2"
            hlp:Form.Label="Texture"
            DisplayMemberPath="Key"
            IsEnabled="{Binding State.TextureSource, Converter={StaticResource nn2bc}}"
            ItemsSource="{Binding State.TextureSource.Entries, Mode=OneWay}"
            SelectedValue="{Binding State.SelectedFace.SelectedTexture}"
            SelectedValuePath="Value" />
        <ComboBox
            Grid.Row="6"
            Grid.Column="2"
            hlp:Form.Label="Flags"
            ItemsSource="{ct:EnumValProvider EnumType={x:Type geo:GeoMaterialFlags}}"
            SelectedItem="{Binding State.SelectedFace.Flags}" />
    </Grid>
</UserControl>
