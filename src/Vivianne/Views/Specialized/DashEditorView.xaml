<UserControl
    x:Class="TheXDS.Vivianne.Views.Specialized.DashEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fsh="clr-namespace:TheXDS.Vivianne.ViewModels.Fsh;assembly=Vivianne.Common"
    xmlns:gn="http://schemas.thexds.local/ganymede"
    xmlns:hlp="clr-namespace:TheXDS.Vivianne.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcart="http://schemas.thexds.local/mcart"
    xmlns:st="clr-namespace:TheXDS.Vivianne.Resources.Strings.Views"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vc="clr-namespace:TheXDS.Vivianne.ValueConverters"
    d:DataContext="{d:DesignInstance Type=fsh:DashEditorViewModel}"
    Background="{ui:ThemeResource ControlSolidFillColorDefaultBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <mcart:NotNullToBooleanConverter x:Key="nn2bc" />
        <vc:GuageDrawingContext x:Key="gdc" />
    </UserControl.Resources>
    <DockPanel>
        <ScrollViewer
            Width="430"
            Height="520"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Expander Header="{x:Static st:DashEditorView.Basics}" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="{x:Static st:DashEditorView.DialColor}" />
                        <ui:NumberBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.DialColorX}" />
                        <ui:NumberBox
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.DialColorY}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            hlp:Form.Label="{x:Static st:DashEditorView.DialWidthBase}"
                            Maximum="30"
                            Value="{Binding State.DialWidthBase}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.DialWidthTip}"
                            Maximum="30"
                            Value="{Binding State.DialWidthTip}" />
                    </Grid>
                </Expander>
                <Expander
                    Header="{x:Static st:DashEditorView.SteeringWheelProps}"
                    IsEnabled="{Binding State.Steering, Mode=OneWay, Converter={StaticResource nn2bc}}"
                    IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="{x:Static st:DashEditorView.Position}" />
                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.Rotation}" />
                        <ui:NumberBox
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SteeringXPosition}" />
                        <ui:NumberBox
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SteeringYPosition}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Steering.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SteeringXRotation}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Steering.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SteeringYRotation}" />
                    </Grid>
                </Expander>
                <Expander Header="{x:Static st:DashEditorView.Speedometer}" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <ui:NumberBox
                            hlp:Form.Label="{x:Static st:DashEditorView.Min}"
                            Maximum="{Binding State.SpeedometerMax, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerMin}" />
                        <ui:NumberBox
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.Max}"
                            Maximum="32767"
                            Minimum="{Binding State.SpeedometerMin, Mode=OneWay}"
                            Value="{Binding State.SpeedometerMax}" />
                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.Center}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerCenterX}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerCenterY}" />
                        <ui:NumberBox
                            Grid.Row="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.CenterOff}"
                            Maximum="50"
                            Minimum="0"
                            Value="{Binding State.SpeedometerCenterOffset}" />
                        <ui:NumberBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.TipOff}"
                            Maximum="50"
                            Minimum="0"
                            Value="{Binding State.SpeedometerEdgeOffset}" />
                        <TextBlock
                            Grid.Row="3"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.MinCoords}" />
                        <ui:NumberBox
                            Grid.Row="3"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerMinX}" />
                        <ui:NumberBox
                            Grid.Row="3"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerMinY}" />
                        <TextBlock
                            Grid.Row="4"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.MaxCoords}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerMaxX}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.SpeedometerMaxY}" />
                    </Grid>
                </Expander>
                <Expander Header="{x:Static st:DashEditorView.Tacho}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <ui:NumberBox
                            hlp:Form.Label="{x:Static st:DashEditorView.Min}"
                            Maximum="{Binding State.TachometerMax, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerMin}" />
                        <ui:NumberBox
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.Max}"
                            Maximum="32767"
                            Minimum="{Binding State.TachometerMin, Mode=OneWay}"
                            Value="{Binding State.TachometerMax}" />
                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.Center}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerCenterX}" />
                        <ui:NumberBox
                            Grid.Row="1"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerCenterY}" />
                        <ui:NumberBox
                            Grid.Row="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.CenterOff}"
                            Maximum="50"
                            Minimum="0"
                            Value="{Binding State.TachometerCenterOffset}" />
                        <ui:NumberBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            hlp:Form.Label="{x:Static st:DashEditorView.TipOff}"
                            Maximum="50"
                            Minimum="0"
                            Value="{Binding State.TachometerEdgeOffset}" />
                        <TextBlock
                            Grid.Row="3"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.MinCoords}" />
                        <ui:NumberBox
                            Grid.Row="3"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerMinX}" />
                        <ui:NumberBox
                            Grid.Row="3"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerMinY}" />
                        <TextBlock
                            Grid.Row="4"
                            VerticalAlignment="Center"
                            Text="{x:Static st:DashEditorView.MaxCoords}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerMaxX}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.TachometerMaxY}" />
                    </Grid>
                </Expander>
                <Expander Header="{x:Static st:DashEditorView.Gears}" IsEnabled="{Binding State.GearIndicator, Mode=OneWay, Converter={StaticResource nn2bc}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="4" Text="{x:Static st:DashEditorView.GearCoords}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="1"
                            hlp:Form.Label="X"
                            Maximum="{Binding State.Cabin.Width, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.GearXPosition}" />
                        <ui:NumberBox
                            Grid.Row="4"
                            Grid.Column="2"
                            hlp:Form.Label="Y"
                            Maximum="{Binding State.Cabin.Height, Mode=OneWay}"
                            Minimum="0"
                            Value="{Binding State.GearYPosition}" />
                    </Grid>
                </Expander>
            </StackPanel>
        </ScrollViewer>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Slider
                Grid.Row="1"
                Width="180"
                LargeChange="30"
                Maximum="180"
                Minimum="-180"
                TickFrequency="30"
                TickPlacement="TopLeft"
                Value="{Binding State.PreviewSteerAngle}" />
            <Border
                hlp:Form.MouseTrackingOverlay="True"
                BorderBrush="{StaticResource MainAreaAdaptiveBackground}"
                BorderThickness="1">
                <Canvas
                    Width="640"
                    Height="480"
                    ClipToBounds="True">
                    <Rectangle Width="640" Height="480">
                        <Rectangle.Fill>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="White" />
                                <GradientStop Offset="0.55" Color="SkyBlue" />
                                <GradientStop Offset="0.6" Color="ForestGreen" />
                                <GradientStop Offset="1" Color="DarkGreen" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Image
                        Width="640"
                        Height="480"
                        Stretch="None">
                        <Image.Source>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <vc:FshImageConverter />
                                </MultiBinding.Converter>
                                <Binding Mode="OneWay" Path="State.Cabin" />
                            </MultiBinding>
                        </Image.Source>
                    </Image>
                    <Image Source="{Binding State.PreviewGauge, Converter={StaticResource gdc}, Mode=OneWay}" />
                    <Image
                        Canvas.Left="{Binding State.GearLeft}"
                        Canvas.Top="{Binding State.GearTop}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Stretch="None">
                        <Image.Source>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <vc:FshImageConverter />
                                </MultiBinding.Converter>
                                <Binding Mode="OneWay" Path="State.GearIndicator" />
                            </MultiBinding>
                        </Image.Source>
                    </Image>
                    <Image
                        Canvas.Left="{Binding State.SteeringLeft}"
                        Canvas.Top="{Binding State.SteeringTop}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Stretch="None">
                        <Image.RenderTransform>
                            <RotateTransform Angle="{Binding State.PreviewSteerAngle, Mode=OneWay}" CenterX="{Binding State.Steering.XRotation, Mode=OneWay}" CenterY="{Binding State.Steering.YRotation, Mode=OneWay}" />
                        </Image.RenderTransform>
                        <Image.Source>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <vc:FshImageConverter />
                                </MultiBinding.Converter>
                                <Binding Mode="OneWay" Path="State.Steering" />
                            </MultiBinding>
                        </Image.Source>
                    </Image>
                </Canvas>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
