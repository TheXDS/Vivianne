<UserControl
    x:Class="TheXDS.Vivianne.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hlp="clr-namespace:TheXDS.Vivianne.Helpers"
    xmlns:local="clr-namespace:TheXDS.Vivianne.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mdlfe="clr-namespace:TheXDS.Vivianne.Models.Fe;assembly=VivLib"
    xmlns:mdlviv="clr-namespace:TheXDS.Vivianne.Models.Viv;assembly=VivLib"
    xmlns:st="clr-namespace:TheXDS.Vivianne.Resources.Strings.Views"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:TheXDS.Vivianne.ViewModels;assembly=Vivianne.Common"
    Height="400"
    MaxWidth="800"
    d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
    mc:Ignorable="d">
    <TabControl Grid.Row="1" Margin="10">
        <TabItem Header="{x:Static st:SettingsView.LauncherSettings}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Folder16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="Body"
                                    Text="{x:Static st:SettingsView.NFS2RootDirectory}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding State.Nfs2Path, Mode=OneWay}" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:Button Command="{Binding BrowseNfs2PathCommand, Mode=OneWay}" Content="{x:Static st:SettingsView.Browse}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Folder16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="Body"
                                    Text="{x:Static st:SettingsView.NFS3RootDirectory}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding State.Nfs3Path, Mode=OneWay}" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:Button Command="{Binding BrowseNfs3PathCommand, Mode=OneWay}" Content="{x:Static st:SettingsView.Browse}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Folder16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="Body"
                                    Text="{x:Static st:SettingsView.NFS4RootDirectory}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding State.Nfs4Path, Mode=OneWay}" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:Button Command="{Binding BrowseNfs4PathCommand, Mode=OneWay}" Content="{x:Static st:SettingsView.Browse}" />
                    </ui:CardControl>
                    <Expander Header="{x:Static st:SettingsView.AdvancedSettings}">
                        <StackPanel>
                            <ui:CardControl Icon="{ui:SymbolIcon Symbol=WindowConsole20}">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ui:TextBlock
                                            Grid.Row="0"
                                            FontTypography="Body"
                                            Text="Preferred NFS2 executable" />
                                    </Grid>
                                </ui:CardControl.Header>
                                <ComboBox
                                    Width="200"
                                    ItemsSource="{Binding AvailableNfs2ExeNames, Mode=OneWay}"
                                    SelectedItem="{Binding State.Nfs2PreferredExe, Mode=TwoWay}" />
                            </ui:CardControl>
                            <ui:CardControl Icon="{ui:SymbolIcon Symbol=WindowConsole20}">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ui:TextBlock
                                            Grid.Row="0"
                                            FontTypography="Body"
                                            Text="{x:Static st:SettingsView.Nfs2ExeLaunchArguments}" />
                                        <ui:TextBox
                                            Grid.Row="1"
                                            Margin="0,5,0,0"
                                            Text="{Binding State.Nfs2LaunchArgs}" />
                                    </Grid>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                            <ui:CardControl Icon="{ui:SymbolIcon Symbol=WindowConsole20}">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ui:TextBlock
                                            Grid.Row="0"
                                            FontTypography="Body"
                                            Text="{x:Static st:SettingsView.Nfs3ExeLaunchArguments}" />
                                        <ui:TextBox
                                            Grid.Row="1"
                                            Margin="0,5,0,0"
                                            Text="{Binding State.Nfs4LaunchArgs}" />
                                    </Grid>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                            <ui:CardControl Icon="{ui:SymbolIcon Symbol=WindowConsole20}">
                                <ui:CardControl.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ui:TextBlock
                                            Grid.Row="0"
                                            FontTypography="Body"
                                            Text="{x:Static st:SettingsView.Nfs4ExeLaunchArguments}" />
                                        <ui:TextBox
                                            Grid.Row="1"
                                            Margin="0,5,0,0"
                                            Text="{Binding State.Nfs4LaunchArgs}" />
                                    </Grid>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="{x:Static st:SettingsView.General}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Document16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="{x:Static st:SettingsView.FileBackup}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Static st:SettingsView.BackupFilesUponSaving}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.AutoBackup}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Document16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="{x:Static st:SettingsView.RecentFiles}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Static st:SettingsView.NumberOfRecentFilesToKeepOnTheList}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:NumberBox
                            Grid.Row="1"
                            Width="150"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Maximum="100"
                            Minimum="0"
                            Value="{Binding State.RecentFilesCount}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Globe24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Preferred FeData language" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Specifies the preferred FeData language to use when showing FeData information, such as Car colors or performance metrics."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ComboBox
                            Width="250"
                            DisplayMemberPath="Name"
                            IsEditable="False"
                            ItemsSource="{ct:NamedEnumValProvider EnumType={x:Type mdlfe:FeDataLang}}"
                            SelectedValue="{Binding State.PreferredFeDataLang}"
                            SelectedValuePath="Value" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Open24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="File associations" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Click this button to associate known file extensions with Vivianne."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:Button
                            Command="{Binding SetFileAssociationsCommand, Mode=OneWay}"
                            Content="Associate files"
                            Icon="{ui:SymbolIcon Symbol=Shield24}" />
                    </ui:CardControl>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="{x:Static st:SettingsView.VIVEditor}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl hlp:Form.BetaIndicator="True" Icon="{ui:SymbolIcon Symbol=Document16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="{x:Static st:SettingsView.CheckSerialNumbers}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Static st:SettingsView.EnableSerialNumberCheckupWhenSavingAVIVFile}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Viv_CheckSnOnSave}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=ArrowSort24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Directory sorting" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Specifies the sorting to use on the VIV directory"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ComboBox
                            Width="250"
                            DisplayMemberPath="Name"
                            IsEditable="False"
                            ItemsSource="{ct:NamedEnumValProvider EnumType={x:Type mdlviv:SortType}}"
                            SelectedValue="{Binding State.Viv_FileSorting}"
                            SelectedValuePath="Value" />
                    </ui:CardControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="BNK editor">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Info16}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Display info panel by default" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, allows the info panel to be displayed by default when opening a BNK file."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Bnk_InfoOpenByDefault}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Speaker224}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Default volume normalization" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Specifies the default max volume when using the 'Normalize Volume' tool in the BNK editor."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:NumberBox
                            Width="150"
                            LargeChange="0.1"
                            Maximum="1.0"
                            Minimum="0.0"
                            SmallChange="0.01"
                            Value="{Binding State.Bnk_DefaultNormalization, StringFormat={}{0:0.00}}" />
                    </ui:CardControl>
                    <ui:CardControl hlp:Form.BetaIndicator="True" Icon="{ui:SymbolIcon Symbol=Delete24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Keep trash outside of sample data" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, forces the BNK editor to keep any unreferenced trash data that might exist outside of the sample data of all audio streams."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Bnk_KeepTrash}" />
                    </ui:CardControl>
                    <ui:CardControl hlp:Form.BetaIndicator="True" Icon="{ui:SymbolIcon Symbol=Broom24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Trim looping audio on cleanup" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, running the cleanup tool will also trim the looping sections of audio on all streams by removing the sections outside their respective loops."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Bnk_TrimLoopsOnCleanup}" />
                    </ui:CardControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="Carp editor">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=DocumentMultipleSync20}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Sync Carp changes" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, syncs changes made on the current Carp file for performance data to all FeData files in the VIV directory."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Carp_SyncChanges}" />
                    </ui:CardControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="FeData editor">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=DocumentMultipleSync20}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Sync FeData changes" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, syncs changes made on the current FeData file to the other FeData files in the VIV directory as well as Carp."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Fe_SyncChanges}" />
                    </ui:CardControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="FCE editor">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=ArrowMove24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Center model automatically" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, the model will be automatically centered when saving an FCE file."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Fce_CenterModel}" />
                    </ui:CardControl>
                    <ui:CardControl hlp:Form.BetaIndicator="True" Icon="{ui:SymbolIcon Symbol=Broom24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="{x:Static st:SettingsView.FCECleanup}" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, the FCE data will be cleaned up upon saving (removing unused names, naming unnamed parts, cleaning out invalid triangle flags, etc.)"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Fce_CleanupOnSave}" IsEnabled="False" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=SquareShadow20}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Enable car shadow by default" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, the FCE editor will enable rendering of the car bounding box shadow by default."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Fce_ShadowByDefault}" />
                    </ui:CardControl>
                    <ui:CardControl Icon="{ui:SymbolIcon Symbol=Image24}">
                        <ui:CardControl.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock
                                    Grid.Row="0"
                                    FontTypography="BodyStrong"
                                    Text="Enumerate all images as textures" />
                                <ui:TextBlock
                                    Grid.Row="1"
                                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                    Text="When enabled, lists all compatible images as textures for rendering FCE models instead of listing .TGA files only."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding State.Fce_EnumerateAllImages}" />
                    </ui:CardControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        <TabItem Header="About">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Image Margin="50" Source="/Resources/Images/vivianne.png" />
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontSize="8"
                    Opacity="0.3">
                    Powered by MCART / Ganymede
                </TextBlock>
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextBlock.FontFamily="{StaticResource MuliLight}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource nfsFont}"
                        FontSize="24">
                        Vivianne
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center">A NFS modding tool</TextBlock>
                    <Separator />
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <TextBlock Width="400" TextWrapping="Wrap">
                            Version<Run Text="{Binding Version, Mode=OneWay}" />
                            <LineBreak /><LineBreak />
                            Created by TheXDS!<LineBreak /><Hyperlink Click="Hyperlink_Click" NavigateUri="https://github.com/TheXDS/Vivianne/">GitHub Repo</Hyperlink>
                            <LineBreak /><LineBreak />
                            Released under the<Hyperlink Click="Hyperlink_Click" NavigateUri="https://mit-license.org/">MIT</Hyperlink>
                            license.<LineBreak /><LineBreak />
                            Special thanks to:<LineBreak />
                            Rata536, AJ_Lethal, Skoti_nfs, VEG, Exotic_Lover, TsTg, pete and the rest of the NFS2/3/4 modding community in our Discord server. You guys are awesome!</TextBlock>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
