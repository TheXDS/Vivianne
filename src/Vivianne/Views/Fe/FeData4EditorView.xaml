                                    Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    hlp:Form.Label="Price"
                                    Value="{Binding State.CompareUpg2.Price, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
