                                <TextBlock
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.CompareUpg2.Acceleration, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="1"
