    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:ct="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:gn="http://schemas.thexds.local/ganymede"
    xmlns:hlp="clr-namespace:TheXDS.Vivianne.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcart="http://schemas.thexds.local/mcart"
    xmlns:md="clr-namespace:TheXDS.Vivianne.Models.Fe;assembly=VivLib"
    xmlns:md4="clr-namespace:TheXDS.Vivianne.Models.Fe.Nfs4;assembly=VivLib"
    xmlns:mdl="clr-namespace:TheXDS.Vivianne.Models;assembly=VivLib"
    xmlns:models="clr-namespace:TheXDS.Vivianne.Models;assembly=Vivianne.Common"
    xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.ObjectModel"
    xmlns:st="clr-namespace:TheXDS.Vivianne.Resources.Strings.Views"
    xmlns:stc="clr-namespace:TheXDS.Vivianne.Resources.Strings;assembly=Vivianne.Common"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:valueconverters="clr-namespace:TheXDS.Vivianne.ValueConverters"
    xmlns:vc="clr-namespace:TheXDS.Vivianne.ValueConverters"
    xmlns:viewmodels="clr-namespace:TheXDS.Vivianne.ViewModels;assembly=Vivianne.Common"
    xmlns:vm="clr-namespace:TheXDS.Vivianne.ViewModels.Fe;assembly=Vivianne.Common"
    d:DataContext="{d:DesignInstance Type=vm:FeData4EditorViewModel}"
    d:DesignWidth="600"
    mc:Ignorable="d">
    <DockPanel>
        <controls:FileEditorCommandBar
            DockPanel.Dock="Top"
            Editor="{Binding}"
            ShowClose="False" />
        <Grid Background="{ui:ThemeResource ControlSolidFillColorDefaultBrush}">
            <ScrollViewer>
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                    </Style>
                    <Style BasedOn="{StaticResource {x:Type ui:TextBox}}" TargetType="ui:TextBox">
                        <Setter Property="Margin" Value="5" />
                    </Style>
                    <Style BasedOn="{StaticResource {x:Type ui:NumberBox}}" TargetType="ui:NumberBox">
                        <Setter Property="Margin" Value="5" />
                    </Style>
                    <Style TargetType="UniformGrid">
                        <Setter Property="Margin" Value="5" />
                        <Setter Property="VerticalAlignment" Value="Top" />
                    </Style>
                    <Style TargetType="GroupBox">
                        <Setter Property="Margin" Value="5" />
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel Margin="10,10,0,10">
                    <Expander Header="{x:Static st:FeDataEditorView.BasicProperties}" IsExpanded="True">
                        <StackPanel Margin="5">
                            <ui:TextBox
                                Margin="5"
                                hlp:Form.Label="{x:Static st:FeDataEditorView.CarName}"
                                Text="{Binding State.CarName, UpdateSourceTrigger=PropertyChanged}" />
                            <mcart:StretchyWrapPanel StretchProportionally="True">
                                <ui:TextBox
                                    Margin="5"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.CarId}"
                                    MaxLength="4"
                                    Text="{Binding State.CarId, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox
                                    Margin="5"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.SerialNumber}"
                                    Maximum="65535"
                                    Minimum="0"
                                    Value="{Binding State.SerialNumber, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Margin="5"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.CarClass}"
                                    IsEditable="False"
                                    ItemsSource="{ct:EnumValProvider EnumType={x:Type md4:CarClass}}"
                                    SelectedItem="{Binding State.VehicleClass, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox
                                    Margin="5"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.IsPolice}"
                                    DisplayMemberPath="Name"
                                    IsEditable="False"
                                    ItemsSource="{ct:NamedEnumValProvider EnumType={x:Type md4:PursuitFlag}}"
                                    SelectedValue="{Binding State.PoliceFlag, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Value" />
                                <CheckBox Margin="5" IsChecked="{Binding State.IsBonus}">
                                    <TextBlock Text="{x:Static st:FeDataEditorView.IsBonus}" />
                                </CheckBox>
                                <CheckBox Margin="5" IsChecked="{Binding State.Upgradable}">
                                    <TextBlock Text="{x:Static st:FeDataEditorView.Upgradable}" />
                                </CheckBox>
                                <CheckBox Margin="5" IsChecked="{Binding State.IsDlc, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock Text="{x:Static st:FeDataEditorView.IsDLC}" />
                                </CheckBox>
                                <ComboBox
                                    Margin="5"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.RoofType}"
                                    DisplayMemberPath="Name"
                                    IsEditable="False"
                                    ItemsSource="{ct:NamedEnumValProvider EnumType={x:Type md4:RoofFlag}}"
                                    SelectedValue="{Binding State.Roof, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Value" />
                                <ComboBox
                                    Margin="5"
                                    hlp:Form.Label="{x:Static st:FeDataEditorView.EngineLocation}"
                                    DisplayMemberPath="Name"
                                    IsEditable="False"
                                    ItemsSource="{ct:NamedEnumValProvider EnumType={x:Type md:EngineLocation}}"
                                    SelectedValue="{Binding State.EngineLocation, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Value" />
                            </mcart:StretchyWrapPanel>
                        </StackPanel>
                    </Expander>
                    <mcart:StretchyWrapPanel>
                        <Expander
                            MinWidth="200"
                            VerticalAlignment="Stretch"
                            Header="{x:Static st:FeDataEditorView.Compare}"
                            IsExpanded="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Margin="5"
                                    Text="{x:Static st:FeDataEditorView.Acceleration}"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.DefaultCompare.Acceleration}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.DefaultCompare.Acceleration, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="5"
                                    Text="{x:Static st:FeDataEditorView.TopSpeed}"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.DefaultCompare.TopSpeed}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.DefaultCompare.TopSpeed, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="2"
                                    Margin="5"
                                    Text="{x:Static st:FeDataEditorView.Handling}"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.DefaultCompare.Handling}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.DefaultCompare.Handling, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="3"
                                    Margin="5"
                                    Text="{x:Static st:FeDataEditorView.Braking}"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.DefaultCompare.Braking}" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.DefaultCompare.Braking, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="4"
                                    Margin="5"
                                    Text="Overall"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.DefaultCompare.Overall}" />
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.DefaultCompare.Overall, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <ui:NumberBox
                                    Grid.Row="5"
                                    Grid.ColumnSpan="3"
                                    hlp:Form.Label="Price"
                                    Value="{Binding State.DefaultCompare.Price, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Expander>
                        <Expander
                            MinWidth="200"
                            VerticalAlignment="Stretch"
                            Header="{x:Static st:FeDataEditorView.CompareUpgrade1}"
                            IsExpanded="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="3*" />
