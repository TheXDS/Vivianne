                                    Value="{Binding State.CompareUpg2.Handling}" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.CompareUpg2.Handling, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="3"
                                    Margin="5"
                                    Text="{x:Static st:FeDataEditorView.Braking}"
                                    TextAlignment="Right" />
                                <Slider
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="20"
                                    Value="{Binding State.CompareUpg2.Braking}" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="5"
                                    Text="{Binding State.CompareUpg2.Braking, Mode=OneWay}"
                                    TextAlignment="Center" />
                                <TextBlock
                                    Grid.Row="4"
                                    Margin="5"
                                    Text="Overall"
