<UserControl
    x:Class="TheXDS.Vivianne.Views.TexturePreviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:ct="clr-namespace:TheXDS.Vivianne.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:TheXDS.Vivianne.Resources.Strings.Views"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vc="clr-namespace:TheXDS.Vivianne.ValueConverters"
    xmlns:vm="clr-namespace:TheXDS.Vivianne.ViewModels;assembly=Vivianne.Common"
    d:DataContext="{d:DesignInstance Type=vm:TexturePreviewViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="600"
    TextBlock.Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <vc:RawImageConverter x:Key="r2img" />
        <vc:BackgroundToBrushConverter x:Key="bg2b" />
    </UserControl.Resources>
    <DockPanel>
        <ct:FileEditorCommandBar
            Margin="0,0,10,0"
            VerticalContentAlignment="Center"
            DockPanel.Dock="Top"
            Editor="{Binding}"
            ShowClose="False">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Margin="10,0" VerticalAlignment="Center"><Run Text="{x:Static properties:FshEditorView.Zoom}" /> <Run Text="{Binding ZoomLevel, Mode=OneWay}" /></TextBlock>
                    <Slider
                        x:Name="sldZoom"
                        Width="100"
                        Margin="5"
                        IsSnapToTickEnabled="True"
                        LargeChange="1"
                        Maximum="10.0"
                        Minimum="1.0"
                        SmallChange="0.5"
                        TickFrequency="0.125"
                        Value="{Binding ZoomLevel}" />
                    <CheckBox
                        Padding="10,0"
                        IsChecked="{Binding Alpha}"
                        Style="{StaticResource ToggleSwitch}">
                        <TextBlock
                            Margin="10,0"
                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                            Text="{x:Static properties:FshEditorView.Alpha}" />
                    </CheckBox>
                    <TextBlock
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Text="{x:Static properties:FshEditorView.Background}" />
                    <ComboBox
                        Width="180"
                        IsEditable="False"
                        IsEnabled="{Binding Alpha, Mode=OneWay}"
                        ItemsSource="{controls:EnumValProvider EnumType={x:Type vm:BackgroundType}}"
                        SelectedItem="{Binding Background, FallbackValue={x:Static vm:BackgroundType.Checkerboard}}" />
                </StackPanel>
            </ScrollViewer>
        </ct:FileEditorCommandBar>
        <Grid Background="{ui:ThemeResource ControlSolidFillColorDefaultBrush}">
            <ScrollViewer
                x:Name="scvContent"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Border
                    x:Name="brdContent"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{Binding Background, Converter={StaticResource bg2b}, Mode=OneWay}"
                    Cursor="ScrollAll">
                    <Image Stretch="None">
                        <Image.Source>
                            <MultiBinding Converter="{StaticResource r2img}">
                                <Binding Mode="OneWay" Path="State.Data" />
                                <Binding Mode="OneWay" Path="Alpha" />
                            </MultiBinding>
                        </Image.Source>
                        <Image.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                        </Image.LayoutTransform>
                    </Image>
                </Border>
            </ScrollViewer>
            <StackPanel Margin="10" HorizontalAlignment="Left">
                <Expander
                    Width="180"
                    Background="{StaticResource DarkBackground}"
                    ExpandDirection="Right"
                    Header="{x:Static properties:FshEditorView.EditTexture}"
                    IsExpanded="False">
                    <StackPanel Margin="-11" Background="{StaticResource DarkBackground}">
                        <Button
                            Margin="5"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ReplaceTextureCommand, Mode=OneWay}"
                            Content="{x:Static properties:FshEditorView.Replace}" />
                        <Button
                            Margin="5"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ExportTextureCommand, Mode=OneWay}"
                            Content="{x:Static properties:FshEditorView.Export}" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
