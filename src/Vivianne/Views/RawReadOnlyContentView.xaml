<UserControl
    x:Class="TheXDS.Vivianne.Views.RawReadOnlyContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TheXDS.Vivianne.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vc="clr-namespace:TheXDS.Vivianne.ValueConverters"
    xmlns:viewmodels="clr-namespace:TheXDS.Vivianne.ViewModels;assembly=Vivianne.Common"
    d:DataContext="{d:DesignInstance Type=viewmodels:RawContentViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{ui:ThemeResource ControlSolidFillColorDefaultBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <vc:ByteToTextConverter x:Key="b2str" />
    </UserControl.Resources>
    <Grid>
        <TextBox
            Margin="10"
            Background="{x:Null}"
            BorderBrush="{x:Null}"
            FontFamily="Cascadia Mono"
            IsReadOnly="True"
            Text="{Binding RawFile, Mode=OneWay, Converter={StaticResource b2str}}"
            TextWrapping="Wrap" />
        <ui:Button
            Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Command="{Binding CopyCommand, Mode=OneWay}"
            Icon="{ui:SymbolIcon Symbol=Copy24}" />
    </Grid>
</UserControl>
