<UserControl
    x:Class="TheXDS.Vivianne.Views.VivEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:carp2vm="clr-namespace:TheXDS.Vivianne.ViewModels.Carp.Nfs2;assembly=Vivianne.Common"
    xmlns:carp3vm="clr-namespace:TheXDS.Vivianne.ViewModels.Carp.Nfs3;assembly=Vivianne.Common"
    xmlns:carp4vm="clr-namespace:TheXDS.Vivianne.ViewModels.Carp.Nfs4;assembly=Vivianne.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fce4vm="clr-namespace:TheXDS.Vivianne.ViewModels.Fce.Nfs4;assembly=Vivianne.Common"
    xmlns:gn="http://schemas.thexds.local/ganymede"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mcart="http://schemas.thexds.local/mcart"
    xmlns:st="clr-namespace:TheXDS.Vivianne.Resources.Strings.Views"
    xmlns:st2="clr-namespace:TheXDS.Vivianne.Resources.Strings.ViewModels;assembly=Vivianne.Common"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vc2="clr-namespace:TheXDS.Vivianne.ValueConverters"
    xmlns:vcarp="clr-namespace:TheXDS.Vivianne.Views.Carp"
    xmlns:views="clr-namespace:TheXDS.Vivianne.Views"
    xmlns:viewsSpec="clr-namespace:TheXDS.Vivianne.Views.Specialized"
    xmlns:viv="clr-namespace:TheXDS.Vivianne.ViewModels.Viv;assembly=Vivianne.Common"
    xmlns:vm="clr-namespace:TheXDS.Vivianne.ViewModels;assembly=Vivianne.Common"
    x:Name="ucRoot"
    d:DataContext="{d:DesignInstance Type=viv:VivEditorViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <vc2:ByteCountConverter x:Key="sizeConv" />
        <vc2:FileExtensionToIconConverter x:Key="ficon" />
        <vc2:FileExtensionToColorConverter x:Key="fcolor" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <DockPanel>
            <RadioButton
                Height="42"
                Margin="0,0,0,5"
                HorizontalAlignment="Stretch"
                Command="{Binding OpenFileCommand, Mode=OneWay}"
                DockPanel.Dock="Top"
                GroupName="VivDirectory"
                IsChecked="True">
                <RadioButton.Template>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="PART_SelectionBg" CornerRadius="10,0,0,10">
                            <TextBlock
                                x:Name="PART_title"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static st:VivInfoView.VIVInformation}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="PART_SelectionBg" Property="Background" Value="{ui:ThemeResource ControlSolidFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </RadioButton.Template>
            </RadioButton>
            <mcart:StretchyWrapPanel
                Margin="5"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal">
                <ui:Button
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Command="{Binding ImportFileCommand}"
                    Icon="{ui:SymbolIcon Symbol=Add24}"
                    ToolTip="{x:Static st2:VivEditorViewModel.ImportFile}" />
                <ui:Button
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Command="{Binding NewFromTemplateCommand}"
                    Icon="{ui:SymbolIcon Symbol=New24}"
                    ToolTip="{x:Static st2:VivEditorViewModel.NewFromTemplate}" />
                <ui:Button
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Command="{Binding SaveCommand}"
                    Icon="{ui:SymbolIcon Symbol=Save24}"
                    ToolTip="{x:Static st2:VivEditorViewModel.SaveVivFile}" />
                <ui:Button
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    Command="{Binding SaveAsCommand}"
                    Icon="{ui:SymbolIcon Symbol=SaveArrowRight24}"
                    ToolTip="{x:Static st2:VivEditorViewModel.SaveVivFileAs}" />
            </mcart:StretchyWrapPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl MinWidth="150" ItemsSource="{Binding State.Directory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton
                                Margin="0,0,0,5"
                                HorizontalAlignment="Stretch"
                                Command="{Binding DataContext.OpenFileCommand, ElementName=ucRoot, Mode=OneWay}"
                                CommandParameter="{Binding Mode=OneWay}"
                                GroupName="VivDirectory">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border
                                            x:Name="PART_SelectionBg"
                                            CornerRadius="10,0,0,10"
                                            ToolTip="{x:Static st2:VivEditorViewModel.OpenExternally}">
                                            <DockPanel Margin="10,5">
                                                <ui:Button
                                                    x:Name="PART_btnRemove"
                                                    Command="{Binding DataContext.RemoveFileCommand, ElementName=ucRoot, Mode=OneWay}"
                                                    CommandParameter="{Binding Mode=OneWay}"
                                                    DockPanel.Dock="Right"
                                                    Icon="{ui:SymbolIcon Symbol=Delete16}"
                                                    Style="{StaticResource SmallUiEditButton}"
                                                    ToolTip="{x:Static st2:VivEditorViewModel.Remove}" />
                                                <ui:Button
                                                    x:Name="PART_btnRename"
                                                    Command="{Binding DataContext.RenameFileCommand, ElementName=ucRoot, Mode=OneWay}"
                                                    CommandParameter="{Binding Mode=OneWay}"
                                                    DockPanel.Dock="Right"
                                                    Style="{StaticResource SmallUiEditButton}"
                                                    ToolTip="{x:Static st2:VivEditorViewModel.Rename}" />
                                                <ui:Button
                                                    x:Name="PART_btnExport"
                                                    Command="{Binding DataContext.ExportFileCommand, ElementName=ucRoot, Mode=OneWay}"
                                                    CommandParameter="{Binding Mode=OneWay}"
                                                    DockPanel.Dock="Right"
                                                    Icon="{ui:SymbolIcon Symbol=Save16}"
                                                    Style="{StaticResource SmallUiEditButton}"
                                                    ToolTip="{x:Static st2:VivEditorViewModel.Export}" />
                                                <ui:SymbolIcon
                                                    Margin="0,0,5,0"
                                                    Filled="True"
                                                    FontSize="16"
                                                    Foreground="{Binding Key, Mode=OneWay, Converter={StaticResource fcolor}}"
                                                    Symbol="{Binding Key, Mode=OneWay, Converter={StaticResource ficon}}" />
                                                <StackPanel Margin="0,0,10,0">
                                                    <TextBlock
                                                        x:Name="PART_filename"
                                                        FontSize="16"
                                                        Text="{Binding Key, Mode=OneWay}" />
                                                    <TextBlock x:Name="PART_filesize" FontSize="9">
                                                        Size:<Run Text="{Binding Value, Mode=OneWay, Converter={StaticResource sizeConv}}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="PART_SelectionBg" Property="Background" Value="{ui:ThemeResource ControlSolidFillColorDefaultBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="PART_btnRemove" Property="Visibility" Value="Hidden" />
                                                <Setter TargetName="PART_btnRename" Property="Visibility" Value="Hidden" />
                                                <Setter TargetName="PART_btnExport" Property="Visibility" Value="Hidden" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
        <Border Grid.Column="1">
            <gn:NavigationHost
                Navigator="{Binding ChildNavService}"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
                <gn:NavigationHost.VisualResolver>
                    <gn:WpfResolverStack>
                        <gn:ResolverEntry View="{x:Type vcarp:Carp2EditorView}" ViewModel="{x:Type carp2vm:CarpEditorViewModel}" />
                        <gn:ResolverEntry View="{x:Type views:Carp3EditorView}" ViewModel="{x:Type carp3vm:CarpEditorViewModel}" />
                        <gn:ResolverEntry View="{x:Type views:Carp4EditorView}" ViewModel="{x:Type carp4vm:CarpEditorViewModel}" />
                        <gn:ResolverEntry View="{x:Type Control}" ViewModel="{x:Type vm:ExternalFileViewModel}" />
                        <gn:ResolverEntry View="{x:Type views:RawReadOnlyContentView}" ViewModel="{x:Type vm:RawContentViewModel}" />
                        <gn:ResolverEntry View="{x:Type viewsSpec:ComingSoonView}" ViewModel="{x:Type vm:ComingSoonViewModel}" />
                        <gn:WpfConventionVisualResolver />
                        <gn:WpfConstResolver View="{x:Type viewsSpec:MissingView}" />
                    </gn:WpfResolverStack>
                </gn:NavigationHost.VisualResolver>
            </gn:NavigationHost>
        </Border>
    </Grid>
</UserControl>
